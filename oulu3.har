t\t\t\t\t\t\t\t\t\t<div class=\"diet diet_MU\" title=\"Kananmuna-allergia\">\n\t\t\t\t\t\t\t\t<img src=\"https://ravintolapalvelut.iss.fi/wp-content/plugins/ceepos-lunch-restaurants/assets/iss-munaton.png\" alt=\"Kananmuna-allergia\" class=\"diet_icon\" />\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"menu_item_info\" data-info=\"\" onclick=\"return ceepos_show_menu_item_info(this);\">\n\t\t\t\t\t\t\t<img src=\"https://ravintolapalvelut.iss.fi/wp-content/plugins/ceepos-lunch-restaurants/assets/iss-info.png\" alt=\"Info\" class=\"diet_icon\" />\t\t\t\t\t\t</div>\n\t\t\t\t\t\t \n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t\n\t</div>\n\t</div>\n</div>\n<div class=\"die_happy_container\"><div class=\"diets_info_container\"><!-- wp:paragraph -->\n<p>L = Laktoositon, G = Gluteeniton, M = Maidoton, V = Vegaaninen, CO2 Aterian pÃ¤Ã¤ruoka / 100g</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>DieettimerkinnÃ¤t voivat poiketa yllÃ¤ olevasta listauksesta, joten tarkistathan aina ravintolassa ruoan soveltuvuuden omaan&nbsp;erityisruokavalioosi.</p>\n<!-- /wp:paragraph --></div></div><div class=\"print_container\">\n\t\t<select id=\"print_mode\">\n\t\t\t<option value=\"\">Valitse tulostusnÃ¤kymÃ¤</option>\n\t\t\t<option value=\"week\">Viikon ruokalista</option>\n\t\t\t<option value=\"day\">PÃ¤ivÃ¤n ruokalista</option>\n\t\t\t<option value=\"day_with_info\">PÃ¤ivÃ¤n ruokalista sis. ainekset</option>\n\t\t</select>\n\t\t<button onclick=\"return ceepos_print_menu(this);\">Tulosta ruokalista</button>\n\t</div>\n\t\n\t<div class=\"restaurant_info_container\">\n\t\t\t<div class=\"restaurant_opening_hours_container\">\n\t\t\t</div>\n\t\t\t\t<div class=\"restaurant_contact_container\"><div class=\"restaurant_contact\"><p>haukipudas@iss.fi<br />p. 050 598 4371</p></div></div></div>\n\t\t<div class=\"ceepos_info_popup\" style=\"display: none;\">\n\t<div class=\"ceepos_info_container\"></div>\n\t<button class=\"ceepos_close_info\" onclick=\"return ceepos_close_info_popup(this);\">Sulje</button>\n</div>\n<div class=\"ceepos_info_background\" style=\"display: none;\"></div>\n<script type=\"text/html\" id=\"ceepos_print_week_css\">@import url('https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap');\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans';\r\n  font-style: normal;\r\n  font-weight: 400;\r\n  font-stretch: 100%;\r\n  font-display: swap;\r\n  src: url(/wp-content/themes/storefront-cpu-commerce/fonts/Noto_Sans/notoSans_regular.woff2) format('woff2');\r\n}\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans Bold';\r\n  font-style: normal;\r\n  font-weight: 700;\r\n  font-stretch: 100%;\r\n  font-display: swap;\r\n  src: url(/wp-content/themes/storefront-cpu-commerce/fonts/Noto_Sans/notoSans_bold.woff2) format('woff2');\r\n}\r\n\r\n:root {\r\n\t--theme-light: #ffffff;\r\n\t--theme-light-medium: #0084FF;\r\n\t--theme-medium: #153AC7;\r\n\t--theme-dark: #030037;\r\n}\r\n\r\nbody {\r\n    font-family: \"Noto Sans\", sans-serif;\r\n    margin: 1em;\r\n}\r\n\r\n/* Header */\r\n\r\n.restaurant_header_container {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    gap: 2em;\r\n    width: 100%;\r\n}\r\n\r\n.restaurant_header_container > .restaurant_contact {\r\n   display: none;\r\n}\r\n\r\n.restaurant_contact p {\r\n    margin: 0;\r\n    font-size: .75rem;\r\n}\r\n\r\n.restaurant_info_container {\r\n    /*display: flex;*/\r\n    display: none;\r\n    justify-content: space-between;\r\n}\r\n.restaurant_name_container {\r\n    margin-right: auto;\r\n}\r\n.restaurant_name_container h1 {\r\n    margin: 0;\r\n    font-size: 1.5rem;\r\n    font-family: \"Noto Sans Bold\", sans-serif;\r\n}\r\n.restaurant_image_container {\r\n    order: 1;\r\n    margin-right: 1em;\r\n}\r\n.restaurant_image_container img {\r\n    max-height: 85px;\r\n}\r\n.restaurant_opening_hours_container {\r\n    order: 3;\r\n}\r\n.restaurant_opening_hours_container .lunch_hours {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    gap: 2em;\r\n    font-size: .75rem;\r\n}\r\n\r\n/**/\r\n\r\nbody > h1 {\r\n    font-size: .875rem;\r\n    margin: .5rem 0;\r\n}\r\n\r\n.restaurant_menu_days {\r\n    display: grid;\r\n    grid-auto-flow: column;\r\n    grid-auto-columns: 1fr;\r\n    gap: 10px;\r\n}\r\n.day_header {\r\n    background-color: var(--theme-dark);\r\n    color: var(--theme-light);\r\n    padding: .5rem 1rem;\r\n    border-radius: 60px;\r\n    text-align: center;\r\n    font-weight: 400;\r\n    font-size: 1rem;\r\n}\r\n.day_menu_container > h3 {\r\n    font-size: 1rem;\r\n    margin: .25em 0;\r\n    font-family: \"Noto Sans Bold\", sans-serif;\r\n}\r\n.day_menu_container .price {\r\n    font-size: .875rem;\r\n}\r\n.name_price_container {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: space-between;\r\n    margin: .75rem 0 .25rem 0;\r\n}\r\n.name_price_container h3 {\r\n    margin: 0;\r\n    font-size: .875rem;\r\n    font-family: 'Noto Sans Bold';\r\n}\r\n.menu_item_container {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    border-bottom: 1px solid var(--theme-dark);\r\n    padding-bottom: 5px;\r\n    margin: 5px 0;\r\n    gap: .5rem;\r\n}\r\n.menu_item_name,\r\n.menu_items_combined {\r\n     font-size: .75rem;\r\n}\r\n.menu_item_container:has(> .co2_container) {\r\n    display: grid;\r\n    grid-template-columns: 2fr 1fr;\r\n    grid-row-gap: 0;\r\n    padding-bottom: 5px;\r\n    margin: 5px 0;\r\n}\r\n.menu_item_name {\r\n    grid-area: span 2 / span 1;\r\n    display: flex;\r\n    align-items: end;\r\n}\r\n.diets_container {\r\n    display: flex;\r\n    justify-content: flex-end;\r\n    gap: .125rem;\r\n}\r\n.diets_container > * {\r\n\tborder-radius: 60px;\r\n\tline-height: 1rem;\r\n\tfont-size: .75rem;\r\n\tdisplay: flex;\r\n\tjustify-content: center;\r\n\talign-items: center;\r\n}\r\nimg.diet_icon {\r\n    width: 15px !important;\r\n    height: 15px !important;\r\n}\r\n\r\n@page {\r\n  size: A4 landscape;\r\n  margin: 10px;\r\n}\r\n@media print {\r\n  html, body {\r\n    height: 210mm;\r\n    width: 297mm;\r\n  }\r\n}\r\n.co2_container {\r\n  font-size: 6pt;\r\n  font-style: italic;\r\n  text-align: end;\r\n}</script>\n<script type=\"text/html\" id=\"ceepos_print_day_css\">@import url('https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap');\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans';\r\n  font-style: normal;\r\n  font-weight: 400;\r\n  font-stretch: 100%;\r\n  font-display: swap;\r\n  src: url(/wp-content/themes/storefront-cpu-commerce/fonts/Noto_Sans/notoSans_regular.woff2) format('woff2');\r\n}\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans Bold';\r\n  font-style: normal;\r\n  font-weight: 700;\r\n  font-stretch: 100%;\r\n  font-display: swap;\r\n  src: url(/wp-content/themes/storefront-cpu-commerce/fonts/Noto_Sans/notoSans_bold.woff2) format('woff2');\r\n}\r\n\r\n:root {\r\n\t--theme-light: #ffffff;\r\n\t--theme-light-medium: #0084FF;\r\n\t--theme-medium: #153AC7;\r\n\t--theme-dark: #030037;\r\n}\r\nbody {\r\n  font-family: \"Noto Sans\", sans-serif;\r\n  font-size: .75rem;\r\n}\r\n.restaurant_info_container {\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: flex-start;\r\n}\r\n.restaurant_name_container {\r\n  order: 2;\r\n  margin-right: auto;\r\n}\r\n.restaurant_name_container h1 {\r\n  margin: 0;\r\n  font-size: 1.125rem;\r\n  font-family: 'Noto Sans Bold', sans-serif;\r\n}\r\n.restaurant_name_container .restaurant_address {\r\n  font-size: .875rem;\r\n  font-family: 'Noto Sans', sans-serif;\r\n}\r\n.restaurant_image_container {\r\n  order: 1;\r\n}\r\n.restaurant_image_container img {\r\n  max-height: 75px;\r\n}\r\n.restaurant_opening_hours_container {\r\n  order: 3;\r\n}\r\nbody>h1 {\r\n  display: none;\r\n  font-family: \"Noto Sans Bold\", sans-serif;\r\n}\r\n.restaurant_menu_days .day_header {\r\n  margin-bottom: .25em;\r\n  font-family: \"Noto Sans Bold\", sans-serif;\r\n}\r\n.lunch_hours {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  gap: 2em;\r\n}\r\n.name_price_container {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin: .75rem 0 .25rem 0;\r\n}\r\n.name_price_container h3 {\r\n  margin: 0;\r\n  font-family: \"Noto Sans Bold\", sans-serif;\r\n}\r\n.menu_item_container {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: flex-start;\r\n  flex-wrap: wrap;\r\n  border-bottom: 1pt solid var(--theme-dark);\r\n  padding-bottom: .375rem;\r\n  margin: .375rem 0;\r\n  gap: .5rem;\r\n}\r\n.menu_item_name {\r\n  align-self: center;\r\n}\r\n.menu_item_ingredients.combined::after {\r\n  content: '';\r\n  height: 1rem;\r\n  display: block;\r\n}\r\n.menu_item_ingredients {\r\n  order: 3;\r\n  width: 100%;\r\n  font-size: .625rem;\r\n}\r\n.co2_container {\r\n  margin-left: auto;\r\n}\r\n.diets_container {\r\n\tdisplay: flex;\r\n\tgap: .25rem;\r\n}\r\n.diets_container > * {\r\n\tline-height: 1rem;\r\n\tfont-size: .75rem;\r\n\tdisplay: flex;\r\n\tjustify-content: center;\r\n\talign-items: center;\r\n}\r\nimg.diet_icon {\r\n  width: 15px !important;\r\n\theight: 15px !important;\r\n}\r\n\r\n@page {\r\n  size: A4;\r\n  margin: 16px;\r\n}\r\n@media print {\r\n  html, body {\r\n    width: 210mm;\r\n    height: 297mm;\r\n  }\r\n}\r\n.co2_container {\r\n  font-size: 6pt;\r\n  font-style: italic;\r\n}</script>\n<script type=\"text/html\" id=\"ceepos_print_day_info_css\">@import url('https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap');\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans';\r\n  font-style: normal;\r\n  font-weight: 400;\r\n  font-stretch: 100%;\r\n  font-display: swap;\r\n  src: url(/wp-content/themes/storefront-cpu-commerce/fonts/Noto_Sans/notoSans_regular.woff2) format('woff2');\r\n}\r\n\r\n@font-face {\r\n  font-family: 'Noto Sans Bold';\r\n  font-style: normal;\r\n  font-weight: 700;\r\n 