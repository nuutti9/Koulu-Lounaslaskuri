tor {\n\t\tdisplay: grid;\n\t\tgrid-template-columns: repeat(10, 1fr);\n\t\tgrid-template-rows: 1fr 1fr;\n\t\tgrid-row-gap: 1rem;\n\t}\n\t.day_selector > button {\n\t\tgrid-area: span 1 / span 2;\n\t}\n\t.day_selector > a {\n\t\tgrid-row-start: 1;\n\t}\n\t.day_selector > a:first-of-type {\n\t\tgrid-column-start: 1;\n\t\tgrid-column-end: 6;\n\t}\n\t.day_selector > a:last-of-type {\n\t\tgrid-area: span 1 / span 2;\n\t\tgrid-row-start: 1;\n\t\tgrid-column-start: 6;\n\t\tgrid-column-end: 11;\n\t}\n\t.day_selector button {\n\t\tpadding: 1rem;\n\t}\n\t.day_selector > a > button .desktop {\n\t\tdisplay: block !important;\n\t}\n\t.day_selector > a > button .mobile {\n\t\tdisplay: none !important;\n\t}\n\t.menu_item_container:has(> .co2_container) {\n\t\tdisplay: grid;\n    grid-template-columns: 2fr 1fr;\n\t\tgrid-row-gap: 0;\n\t\tpadding-bottom: .5rem;\n    margin: .5rem 0;\n\t\tborder-bottom: 1px solid var(--theme-medium-gray);\n\t}\n\t.menu_item_name {\n\t\tgrid-area: span 2 / span 1;\n\t}\n\t.co2_container {\n\t\tfont-size: .875rem;\n\t}\n\t.menu_items_combined {\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t}\n\t.diets_container {\n\t\tjustify-content: flex-end;\n\t\tgap: .125rem;\n\t}\n\t.die_happy_container {\n\t\tflex-direction: column;\n\t\talign-items: center;\n\t}\n\t.diets_info_container {\n\t\tpadding: 2em 0;\n\t}\n\t.diets_info_container ul {\n\t\tlist-style: none;\n\t\tmargin-left: 0;\n\t}\n\t.print_container {\n\t\tflex-direction: column;\n\t}\n\t.lunch_hours {\n    justify-content: space-between;\n\t}\n}\n\n@media (min-width: 800px) and (max-width: 1175px) {\n\t.day_selector button span.desktop {\n\t\tdisplay: none;\n\t}\n\t.day_selector button span.mobile {\n\t\tdisplay: block;\n\t}\n}\n\n/* Restaurant list page */\n\n.city_restaurants_container {\n\tborder-bottom: 1px solid;\n\tmargin-bottom: 2em;\n\tpadding-bottom: 1em;\n\tdisplay: grid;\n\tgrid-template-columns: repeat(4, 1fr);\n\tgap: 1em;\n}\n\n.restaurant {\n\tdisplay: grid;\n\tgrid-template-columns: 75px 3fr;\n\tgrid-template-rows: 1fr 1fr;\n\tmargin-bottom: 1rem;\n\tgrid-column-gap: 1rem;\n}\n\n.cities_restaurant_image_container {\n\tgrid-area: span 2 / span 1;\n}\n\n.cities_restaurant_image_container img {\n\twidth: 75px;\n\theight: 50px;\n\tobject-fit: contain;\n\tobject-position: left top;\n}\n\n.city_restaurant_link,\n.city_restaurant_address {\n\tgrid-column-start: 2;\n}\n\n.city_restaurant_link {\n\tfont-family: var(--heading);\n\tfont-size: 1.125rem;\n\tline-height: 1.125rem;\n}\n\n@media (min-width: 900px) and (max-width: 1120px) {\n\t.city_restaurants_container {\n\t\tgrid-template-columns: repeat(3, 1fr);\n\t}\n}\n\n@media (min-width: 768px) and (max-width: 900px) {\n\t.city_restaurants_container {\n\t\tgrid-template-columns: repeat(2, 1fr);\n\t}\n}\n\n@media (max-width: 768px) {\n\t.city_restaurants_container {\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t}\n}\n\n/* Restaurant page articles */\n\n.articles_container > a > div {\n\tbox-shadow:  5px 5px 10px #d9d9d9,\n             -5px -5px 10px #ffffff;\n\tborder-radius: var(--border-radius-small);\n}\n\n@media (min-width: 768px) {\n\t.articles_container {\n\t\tdisplay: grid;\n\t\tgrid-template-columns: repeat(5, 1fr);\n\t\tgrid-gap: 1em;\n\t}\n\n\t.articles_container > a {\n\t\theight: 100%;\n\t}\n\n\t.articles_container > a > div {\n\t\theight: 100%;\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tpadding: 2rem;\n\t}\n\t\n\t.articles_container > a {\n\t\tgrid-area: span 1 / span 2;\n\t}\n\t\n\t.articles_container > a:first-of-type,\n\t.articles_container > a:nth-of-type(4),\n\t.articles_container > a:nth-of-type(5),\n\t.articles_container > a:nth-of-type(8),\n\t.articles_container > a:nth-of-type(9),\n\t.articles_container > a:nth-of-type(12),\n\t.articles_container > a:nth-of-type(13) {\n\t\tgrid-area: span 1 / span 3;\n\t}\n}\n\n.articles_container > a > div > h4 {\n\tbackground-color: var(--theme-light-medium);\n\tcolor: var(--theme-light);\n\tfont-family: var(--paragraph);\n\tfont-size: 1.125rem;\n\tpadding: 1.5rem 2rem;\n\twidth: auto;\n\tmargin: auto;\n\ttext-align: center;\n\tborder-radius: var(--border-radius-small);\n}\n\n@media (max-width: 767px) {\n\t.articles_container {\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\tgap: 1em;\n\t}\n\t.articles_container > a > div {\n\t\theight: 100%;\n\t\tdisplay: flex;\n\t\tjustify-content: center;\n\t\talign-items: center;\n\t\tpadding: 2rem;\n\t}\n}\n\n/* Article-page */\n\nul.wp-block-latest-posts {\n\tgap: 1.065em;\n\tflex-wrap: wrap;\n}\n\nul.wp-block-latest-posts li {\n\twidth: 24% !important;\n\tmin-width: 300px;\n\tmargin-right: 0 !important;\n\tbox-shadow: 0 4px 15px 0 rgba(26, 26, 26, .3);\n\twidth: 100%;\n\tposition: relative;\n\toverflow: hidden;\n\tz-index: 2;\n}\n\nul.wp-block-latest-posts li:hover img {\n\ttransition: all .4s ease-in-out;\n\tposition: relative;\n\tz-index: 1;\n}\n\nul.wp-block-latest-posts li > a {\n\tpadding: 1rem 1.5rem 1.75rem 1.5rem;\n\tdisplay: block;\n\ttext-decoration: none !important;\n\tbackground-color: var(--theme-light);\n\tposition: relative;\n\tz-index: 1000;\n}\n\n.wp-block-latest-posts__featured-image a {\n\twidth: 100%;\n\theight: 100%;\n}\n\n.wp-block-latest-posts__featured-image img {\n\tmargin-bottom: 0 !important;\n\tmargin: 0 !important;\n\tmax-width: 100% !important;\n}\n\n@media (min-width: 768px) {\n\t.wp-block-latest-posts__featured-image img {\n\t\theight: 300px;\n\t\twidth: 100%;\n\t\tobject-fit: cover;\n\t}\n}\n\n@media (max-width: 767px) {\n\tul.wp-block-latest-posts li {\n\t\twidth: 100% !important;\n\t}\n\t.wp-block-latest-posts__featured-image img {\n\t\theight: 300px;\n\t\twidth: 100%;\n\t\tobject-fit: cover;\n\t}\n}\n\n/* Frontpage */\n\n.hentry .entry-content .wp-block-cover .wp-block-cover__inner-container a {\n\ttext-decoration: none;\n\tfont-size: 1.75rem;\n\tfont-family: var(--heading);\n}\n\n.hentry .entry-content .wp-block-cover .wp-block-cover__inner-container a:hover {\n\ttext-decorat