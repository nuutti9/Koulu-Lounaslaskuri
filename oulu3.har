\tvar $firstP = $container.find('p').first();\n\t\t\tif ($firstP.length) {\n\t\t\t\tvar text = $firstP.text();\n\t\t\t\tvar items = text.split(',').map(function(item) {\n\t\t\t\t\treturn '<li>' + item.trim() + '</li>';\n\t\t\t\t}).join('');\n\t\t\t\t$firstP.replaceWith('<ul class=\"diet-list\">' + items + '</ul>');\n\t\t\t}\n\t\t}\n\n\t\tfunction resetToParagraph() {\n\t\t\t// Restore original HTML if needed\n\t\t\t$container.html(originalHTML);\n\t\t}\n\n\t\tfunction handleResponsiveChange() {\n\t\t\tvar isMobile = window.innerWidth <= 768;\n\t\t\tvar hasList = $container.find('ul.diet-list').length > 0;\n\n\t\t\tif (isMobile && !hasList) {\n\t\t\t\tconvertToList();\n\t\t\t} else if ( !isMobile && hasList ) {\n\t\t\t\tresetToParagraph();\n\t\t\t}\n\t\t}\n\n\t\t// Run on initial load\n\t\thandleResponsiveChange();\n\n\t\t// Re-run on resize (debounced)\n\t\tvar resizeTimer;\n\t\t$(window).on('resize', function() {\n\t\t\tclearTimeout(resizeTimer);\n\t\t\tresizeTimer = setTimeout(handleResponsiveChange, 100);\n\t\t});\n\n});\n</script>\n\t<script type=\"text/javascript\">\n\t\tjQuery('div.menu_item_info[data-info]:not([onclick])').click(function() { ceepos_show_menu_item_info( jQuery(this) ); });\n\t</script>\n\t<script type=\"application/ld+json\">{\"@context\":\"https://schema.org/\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"name\":\"Etusivu\",\"@id\":\"https://ravintolapalvelut.iss.fi\"}},{\"@type\":\"ListItem\",\"position\":2,\"item\":{\"name\":\"Ravintolat\",\"@id\":\"https://ravintolapalvelut.iss.fi/restaurants\"}},{\"@type\":\"ListItem\",\"position\":3,\"item\":{\"name\":\"Aseman koulu\",\"@id\":\"/aseman-koulu?lang=fi\"}}]}</script>\t<script>\n\t\t(function () {\n\t\t\tvar c = document.body.className;\n\t\t\tc = c.replace(/woocommerce-no-js/, 'woocommerce-js');\n\t\t\tdocument.body.className = c;\n\t\t})();\n\t</script>\n\t<link rel='stylesheet' id='wc-blocks-style-css' href='https://ravintolapalvelut