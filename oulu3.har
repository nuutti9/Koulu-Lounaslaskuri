            "text": "(function( $ ) {\n    \n    $.fn.disableThis = function( disabled_html = '' ) {\n        return this.each(function() {\n            const $el = $( this );\n\n            if ( $el.prop( 'disabled' ) ) {\n                return;\n            }\n\n            // store current HTML for enabling the element again\n            $el.data( 'orig-html', $el.html() );\n\n            if ( disabled_html ) {\n                $el.html( disabled_html );\n            }\n\n            $el.prop( 'disabled', true );\n            $el.addClass( 'disabled' );\n\n        });\n    };\n\n    $.fn.enableThis = function() {\n        return this.each(function() {\n            const $el = $( this );\n            const orig = $el.data( 'orig-html' );\n            if ( orig !== undefined ) {\n                $el.html( orig );\n            }\n            $el.prop( 'disabled', false );\n            $el.removeClass( 'disabled' );\n        });\n    };\n\n}( jQuery ));"
