block;\r\n}\r\n.menu_item_ingredients {\r\n  order: 3;\r\n  width: 100%;\r\n  font-size: .625rem;\r\n}\r\n.co2_container {\r\n  margin-left: auto;\r\n}\r\n.diets_container {\r\n\tdisplay: flex;\r\n\tgap: .25rem;\r\n}\r\n.diets_container > * {\r\n\tline-height: 1rem;\r\n\tfont-size: .75rem;\r\n\tdisplay: flex;\r\n\tjustify-content: center;\r\n\talign-items: center;\r\n}\r\nimg.diet_icon {\r\n  width: 15px !important;\r\n\theight: 15px !important;\r\n}\r\n\r\n@page {\r\n  size: A4;\r\n  margin: 16px;\r\n}\r\n@media print {\r\n  html, body {\r\n    width: 210mm;\r\n    height: 297mm;\r\n  }\r\n}\r\n.co2_container {\r\n  font-size: 6pt;\r\n  font-style: italic;\r\n}</script>\n<script type=\"text/javascript\">\n\tfunction ceepos_print_menu( ctrl ) {\n\t\tvar mode = jQuery('#print_mode').val();\n\t\tif ( mode === '' ) {\n\t\t\treturn false;\n\t\t}\n\t\tvar header = '';\n\t\tvar content = '';\n\t\tvar styles = '.menu_item_info { display: none !important; }';\n\t\tvar restaurant_header = jQuery('.restaurant_name_container').prop('outerHTML') + jQuery('.restaurant_info_container').prop('outerHTML');\n\t\t\nrestaurant_header += jQuery('.restaurant_contact').prop('outerHTML');\n\t\t\n\t\tif ( mode === 'week' ) {\n\t\t\theader = jQuery('h2.week_header').html();\n\t\t\tcontent += jQuery('.week_menu_container').html().replace(new RegExp('display: none;', 'g'), '');\n\t\t\tstyles += '.day_header { display: block; } .menu_item_ingredients { display: none; }' + jQuery('#ceepos_print_week_css').html();\n\t\t}\n\t\telse if ( mode === 'day' ) {\n\t\t\theader = jQuery('.day_menu_container:visible > h3').html();\n\t\t\tcontent += jQuery('.day_menu_container:visible').html().replace(new RegExp('display: none;', 'g'), '');\n\t\t\tstyles += '.day_header { display: block; } .menu_item_ingredients { display: none; }' + jQuery('#ceepos_print_day_css').html();\n\t\t}\n\t\telse if ( mode === 'day_with_info' ) {\n\t\t\theader = jQuery('.day_menu_container:visible > h3').html();\n\t\t\tcontent += jQuery('.day_menu_container:visible').html().replace(new RegExp('display: none;', 'g'), '');\n\t\t\tstyles += '.day_header, .menu_item_ingredients { display: block; }' + jQuery('#ceepos_print_day_info_css').html();\n\t\t}\n\t\ttry\n\t\t{\n\t\t\tvar printWindow = window.open('', '', 'height=300,width=500');\n\t\t\tif ( !printWindow) {\n\t\t\t\talert('Ole hyvÃ¤ ja kytke ponnahdusikkunoiden esto pois kÃ¤ytÃ¶stÃ¤ selaimessa!');\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\tprintWindow.document.write('<html><head><title>'+ header + '</title>');\n\t\n\t\t\t//Print the Table CSS.\n\t\t\tif ( document.getElementById(\"ceepos-data-export-admin-css\") ) {\n\t\t\t\tvar adminCss = document.getElementById(\"ceepos-data-export-admin-css\").outerHTML;\n\t\t\t\tprintWindow.document.write(adminCss);\n\t\t\t}\n\t\t\tprintWindow.document.write('<style type=\"text/css\">' + styles + '</style>');\n\t\t\tprintWindow.document.write('</head>');\n\t\n\t\t\t//Print the DIV contents i.e. the HTML Table.\n\t\t\tprintWindow.document.write('<body>');\n\t\t\tprintWindow.document.write('<div class=\"restaurant_header_container\">' + restaurant_header + '</div>' );\n\t\t\tprintWindow.document.write('<h1>' + header + '</h1>');\n\t\t\tprintWindow.document.write('<div class=\"restaurant_menu_days\">' + content + '</div>');\n\t\t\tprintWindow.document.write('</body>');\n\t\n\t\t\tprintWindow.document.write('</html>');\n\t\t\tprintWindow.document.close();\n\t\t\t\n\t\t\tprintWindow.print();\n\t\t} catch (e) {\n\t\t\tconsole.error(e);\n\t\t}\n\t\t\t\n\t\treturn false;\n\t}\n\tfunction ceepos_show_menu_date( ctrl ) {\n\t\tvar date = jQuery(ctrl).data('date');\n\t\tconsole.log(date);\n\t\tjQuery('.day_menu_container').hide();\n\t\tjQuery('.day_menu_container[data-date=\"'+ date +'\"]').show();\n\t\tjQuery('.day_selector button').removeClass('selected');\n\t\tjQuery(ctrl).addClass('selected');\n\t\treturn false;\n\t}\n\tjQuery(document).ready(function() {\n\t\tif (jQuery('.day_selector button.today').length > 0 ) {\n\t\t\tjQuery('.day_selector button.today').click();\n\t\t} else {\n\t\t\tjQuery(jQuery('.day_selector button.day')[0]).click();\n\t\t}\n\t\t\n\t});\n\tfunction ceepos_show_menu_item_info(ctrl) {\n\t\tvar data = JSON.parse(atob(jQuery(ctrl).data('info')));\n\t\tif ( data.constructor !== Array ) {\n\t\t\tdata = [data];\n\t\t}\n\t\tvar template = wp.template('ceepos-nutritional-values');\n\t\tvar html = template( data );\n\t\tjQuery('.ceepos_info_container').html(html);\n\t\t//console.log(data);\n\t\tjQuery('.ceepos_info_popup,.ceepos_info_background').show();\n\t\tjQuery('.ceepos_info_container').scrollTop(0);\n\t\treturn false;   \n\t}\n\tfunction ceepos_close_info_popup(ctrl) {\n\t\tjQuery('.ceepos_info_popup,.ceepos_info_background').hide();\n\t\treturn false;  \n\t}\n</script>\n<script type=\"text/html\" id=\"tmpl-ceepos-nutritional-values\">\n\t<# _.each(data, function(meal) { #>\n\t<h3>{{meal.Name}}</h3>\n\t<p>{{meal.Ingredients}}</p>\n\n\t<h3>Ravintoarvot / 100 g</h3>\n\t<table class=\"wp-list-table widefat fixed striped table-view-list posts\">\n\t\t<colgroup>\n\t\t\t<col style=\"width: 40%;\"/>\n\t\t\t<col style=\"width: 60%;\"/>\n\t\t</colgroup>\n\t\t<tbody>\n\t<# _.each(meal.NutritionalValues, function(row) { #> \n\t\t<tr>\n\t\t\t<td>{{row.Name}}, {{row.Unit}}</td>\n\t\t\t<td>{{row.ValueFormatted}}</td>\n\t\t</tr>\n\t<# }); #>\n\t\t</tbody>\n\t</table>\n\t<# }); #>\n</script>\n<div class=\"articles_container\">\n\t<a href=\"https://ravintolapalvelut.iss.fi/?post_type=post&p=813\"><div class=\"article\" style=\"background-image: url(https://ravintolapalvelut.iss.fi/wp-content/uploads/sites/30/2025/12/oiva-logo.png);\"><h4>OIVAllista tarjontaa ISS-ravintoloissa</h4></div></a></div>\n\t\t\t</main><!-- #main -->\n\t\t</div><!-- #primary -->\n\n\t\t\n\t\t</div><!-- .col-full -->\n\t</div><!-- #content -->\n\n\t\n\t<footer id=\"colophon\" class=\"site-footer\" role=\"contentinfo\">\n\t\t<div class=\"col-full\">\n\n\t\t\t\t\t\t\t<div class=\"footer-widgets row-