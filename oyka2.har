            "text": "1|#||4|107978|updatePanel|MasterUpdatePanel|\r\n                            \r\n    \r\n    \r\n    <div class=\"emenu_wrapper\">        \r\n        <div class=\"emenu_header\">            \r\n            <a href = \"#emenu_tab_panel_header\"><img title=\"Siirry sisältöön\" src=\"../../../../Images/whiteforwardarrow.png\" style=\"height:25px;\" /></a>\r\n            <div class=\"emenu_logo\">                \r\n                <input type=\"image\" name=\"ctl00$MainContent$EMenuLogo\" id=\"MainContent_EMenuLogo\" src=\"/LookiAromieMenus/FI/Default/LOOKI/Koulut/OrganisationLogo.aspx?Id=d2e2d77a-62fa-4514-9822-087241cf4c7c&amp;FileName=l%C3%B6%C3%B6ki%20iso%20logo.png\" alt=\"LOOKI\" />                \r\n                <h1 class=\"h emenu_subcontent\">\r\n                    <span id=\"MainContent_SecureLabel1\" class=\"fieldtitle\">eRuokalista</span>\r\n                </h1>\r\n            </div>\r\n            <div class=\"emenu_progress\">\r\n                <div class=\"float-right\">\r\n                    <div id=\"MainContent_UpdateProgress2\" style=\"visibility:hidden;display:block;\">\r\n\t\r\n                            <img id=\"MainContent_LoadingImage\" src=\"../../../../Images/Loading.gif\" alt=\"\" />\r\n                            &nbsp;<span id=\"MainContent_LoadingLabel\" class=\"labeltext\">Ladataan...</span>\r\n                        \r\n</div>\r\n                </div>\r\n            </div>\r\n            <div class=\"emenu_language\">\r\n                <div class=\"select-style systembackground float-right width63pixels\">\r\n                    <select name=\"ctl00$MainContent$LanguagesDropDownList\" onchange=\"javascript:setTimeout(&#39;__doPostBack(\\&#39;ctl00$MainContent$LanguagesDropDownList\\&#39;,\\&#39;\\&#39;)&#39;, 0)\" id=\"MainContent_LanguagesDropDownList\" title=\"Vaihda kieli\" class=\"inputfield\">\r\n\t<option selected=\"selected\" value=\"fi\">FI</option>\r\n\t<option value=\"en\">EN</option>\r\n\r\n</s